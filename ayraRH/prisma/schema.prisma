
generator client {
  provider = "prisma-client-js"
}
 
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}
 
model Usuario {
  id String @id @default(uuid())
  nome String
  email String @unique
  senha String
  status Boolean @default(true)

  empresa Empresa @relation(fields: [id_empresa], references: [id])
  setor Setor @relation(fields: [id_setor], references: [id])
  id_empresa String
  id_setor String
 
  data_criacao  DateTime @default(now())
  data_atualizacao DateTime @updatedAt
 
  @@map("usuario")
}

model Setor{
  id String @id @default(uuid())
  nome String
  turno String
  status Boolean @default(true)

  empresa Empresa @relation(fields: [id_empresa], references: [id])
  id_empresa String

  usuario Usuario[]

  data_criacao DateTime @default(now())
  data_atualizacao DateTime @updatedAt

  @@map("setor")
}

model Empresa{
  id String @id @default(uuid())
  nome String
  CNPJ String @unique
  segmento String
  status Boolean @default(true)

  usuario Usuario[]
  setor Setor []

  data_criacao DateTime @default(now())
  data_atualizacao DateTime @updatedAt

  @@map("empresa")

}